# ── Server ──
PORT=3001
NODE_ENV=development
PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=*

# ── PostgreSQL ──
DATABASE_URL=postgresql://postgres:YOURPASSWORD@localhost:5432/sosyalag

# ── Auth ──
# Generate a long random string for production: openssl rand -base64 64
JWT_SECRET=please-change-me-to-a-long-random-string-min-32-chars

# ── Email (Resend.com — free 3000/month) ──
# Get key at https://resend.com — paste here.
# WITHOUT this, verification/reset emails will print to console only (dev mode).
RESEND_API_KEY=
# For production, verify a domain in Resend dashboard, then use:
#   EMAIL_FROM=sosyal-medya.net <noreply@your-domain.com>
EMAIL_FROM=sosyal-medya.net <onboarding@resend.dev>

# ── Tweet Sync ──
X_SYNC_INTERVAL_MIN=30

# ── RSS News ──
RSS_FETCH_INTERVAL_MIN=30

# ── X Tools: Bio Generator (optional AI upgrade) ──
# Get a FREE key at https://console.groq.com (no credit card, ~30 req/min).
# WITHOUT this, the Bio Generator uses the built-in template engine (still works).
# WITH it, bios are AI-generated and much better.
GROQ_API_KEY=
# Optional: override the Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ── X Tools: profile data source (Nitter) ──
# The scraping tools (shadowban, audit, tweet-performance, best-time,
# account-age) read free public X data via Nitter. Public instances are
# volatile. For real reliability, self-host Nitter and set it here
# (comma-separated). Leave blank to use the built-in public instance list.
NITTER_INSTANCES=
# RSSHUB_INSTANCES=
